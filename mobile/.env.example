# Copy to .env.dev (debug builds) and .env.prod (release builds), then fill in real values.
# Never commit the real token files — they are gitignored.

# --- .env.prod values ---
# API_URL=https://api.memoura.app
# APP_BASE_URL=https://memoura.app

# --- .env.dev values ---
# API_URL=https://dev-api.memoura.app
# APP_BASE_URL=https://dev.memoura.app

# Backend API base URL (no trailing slash)
API_URL=https://api.memoura.app

# App web base URL — used for universal links, share messages, deep links
APP_BASE_URL=https://memoura.app

# Google OAuth Web Client ID (same as backend GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=your_google_client_id_here

# RevenueCat API Key (get from RevenueCat dashboard)
REVENUECAT_API_KEY=appl_your_revenuecat_api_key_here

# Mapbox public token (get from mapbox.com)
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# Firebase project ID
FIREBASE_PROJECT_ID=your_firebase_project_id

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!


# Required for FirebaseCoreInternal → GoogleUtilities when Mapbox uses dynamic frameworks
use_modular_headers!

# ── Mapbox Maps SDK ───────────────────────────────────────────────────────────
# Uses Mapbox Maps SDK (v11). Requires a secret token in ~/.netrc:
#   machine api.mapbox.com
#   login maptoken
#   password sk.eyJ1...YOUR_SECRET_TOKEN...
$RNMapboxMapsImpl = 'mapbox'

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

pre_install do |installer|
  $RNMapboxMaps.pre_install(installer)
end

target 'LoveScrum' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    $RNMapboxMaps.post_install(installer)

    # Fix: React-Core-prebuilt is compiled in production mode (NDEBUG), so
    # Sealable ctor/dtor are inlined. Source pods compiled in Debug mode would
    # activate REACT_NATIVE_DEBUG and expect non-inline Sealable — causing
    # "Undefined symbol: facebook::react::Sealable::Sealable()" linker error.
    # Force REACT_NATIVE_PRODUCTION on all pod targets to match the prebuilt.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
        if defs.nil?
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = ['$(inherited)', 'REACT_NATIVE_PRODUCTION=1']
        elsif !defs.include?('REACT_NATIVE_PRODUCTION=1')
          if defs.is_a?(Array)
            defs << 'REACT_NATIVE_PRODUCTION=1'
          else
            config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = [defs, 'REACT_NATIVE_PRODUCTION=1']
          end
        end
      end
    end
  end
end

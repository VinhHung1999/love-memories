    "express-rate-limit": "^8.3.1",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "openai": "^6.22.0",
    "sharp": "^0.33.5",

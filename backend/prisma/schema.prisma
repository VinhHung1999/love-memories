generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Couple {
  id              String    @id @default(uuid())
  name            String?
  anniversaryDate DateTime?
  inviteCode      String?   @unique
  createdAt       DateTime  @default(now())

  users              User[]
  moments            Moment[]
  foodSpots          FoodSpot[]
  recipes            Recipe[]
  cookingSessions    CookingSession[]
  sprints            Sprint[]
  goals              Goal[]
  datePlans          DatePlan[]
  dateWishes         DateWish[]
  expenses           Expense[]
  loveLetters        LoveLetter[]
  customAchievements CustomAchievement[]
  tags               Tag[]
  appSettings        AppSetting[]
  achievements       Achievement[]
  shareLinks         ShareLink[]

  @@map("couples")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String?
  googleId          String?            @unique
  name              String
  avatar            String?
  coupleId          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  couple            Couple             @relation(fields: [coupleId], references: [id])
  comments          MomentComment[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  sentLetters       LoveLetter[]       @relation("SentLetters")
  receivedLetters   LoveLetter[]       @relation("ReceivedLetters")
  refreshTokens     RefreshToken[]

  @@index([coupleId])
  @@map("users")
}

enum LetterStatus {
  DRAFT
  SCHEDULED
  DELIVERED
  READ
}

model LoveLetter {
  id          String        @id @default(uuid())
  senderId    String
  recipientId String
  coupleId    String
  title       String
  content     String
  mood        String?
  status      LetterStatus  @default(DRAFT)
  scheduledAt DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  couple      Couple       @relation(fields: [coupleId], references: [id])
  sender      User          @relation("SentLetters", fields: [senderId], references: [id])
  recipient   User          @relation("ReceivedLetters", fields: [recipientId], references: [id])
  photos      LetterPhoto[]
  audio       LetterAudio[]

  @@index([coupleId])
  @@map("love_letters")
}

model LetterPhoto {
  id        String      @id @default(uuid())
  letterId  String
  filename  String
  url       String
  createdAt DateTime    @default(now())
  letter    LoveLetter  @relation(fields: [letterId], references: [id], onDelete: Cascade)

  @@map("letter_photos")
}

model LetterAudio {
  id        String      @id @default(uuid())
  letterId  String
  filename  String
  url       String
  duration  Float?
  createdAt DateTime    @default(now())
  letter    LoveLetter  @relation(fields: [letterId], references: [id], onDelete: Cascade)

  @@map("letter_audio")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Moment {
  id          String           @id @default(uuid())
  coupleId    String
  title       String
  caption     String?
  date        DateTime
  latitude    Float?
  longitude   Float?
  location    String?
  tags        String[]
  spotifyUrl  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  couple      Couple          @relation(fields: [coupleId], references: [id])
  photos      MomentPhoto[]
  audios      MomentAudio[]
  comments    MomentComment[]
  reactions   MomentReaction[]

  @@index([coupleId])
  @@map("moments")
}

model MomentPhoto {
  id        String   @id @default(uuid())
  momentId  String
  filename  String
  url       String
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id], onDelete: Cascade)

  @@map("moment_photos")
}

model MomentAudio {
  id        String   @id @default(uuid())
  momentId  String
  filename  String
  url       String
  duration  Float?
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id], onDelete: Cascade)

  @@map("moment_audios")
}

model MomentComment {
  id        String   @id @default(uuid())
  momentId  String
  userId    String?
  author    String
  content   String
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("moment_comments")
}

model MomentReaction {
  id        String   @id @default(uuid())
  momentId  String
  emoji     String
  author    String
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id], onDelete: Cascade)

  @@unique([momentId, emoji, author])
  @@map("moment_reactions")
}

model FoodSpot {
  id          String          @id @default(uuid())
  coupleId    String
  name        String
  description String?
  rating      Float           @default(0)
  latitude    Float?
  longitude   Float?
  location    String?
  tags        String[]
  priceRange  Int             @default(2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  couple      Couple         @relation(fields: [coupleId], references: [id])
  photos      FoodSpotPhoto[]
  recipes     Recipe[]

  @@index([coupleId])
  @@map("food_spots")
}

model Recipe {
  id              String                 @id @default(uuid())
  coupleId        String
  title           String
  description     String?
  ingredients      String[]
  ingredientPrices Float[]               @default([])
  steps            String[]
  stepDurations    Int[]                  @default([])
  tags            String[]
  notes           String?
  tutorialUrl     String?
  cooked          Boolean                @default(false)
  foodSpotId      String?
  foodSpot        FoodSpot?              @relation(fields: [foodSpotId], references: [id])
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  couple          Couple                @relation(fields: [coupleId], references: [id])
  photos          RecipePhoto[]
  cookingSessions CookingSessionRecipe[]

  @@index([coupleId])
  @@map("recipes")
}

model CookingSession {
  id          String                 @id @default(uuid())
  coupleId    String
  status      String                 @default("selecting")
  startedAt   DateTime?
  completedAt DateTime?
  totalTimeMs Int?
  notes       String?
  rating      Int?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  couple      Couple                @relation(fields: [coupleId], references: [id])

  recipes     CookingSessionRecipe[]
  items       CookingSessionItem[]
  steps       CookingSessionStep[]
  photos      CookingSessionPhoto[]

  @@index([coupleId])
  @@map("cooking_sessions")
}

model CookingSessionRecipe {
  id          String         @id @default(uuid())
  sessionId   String
  session     CookingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recipeId    String
  recipe      Recipe         @relation(fields: [recipeId], references: [id])
  order       Int
  completedAt DateTime?

  @@map("cooking_session_recipes")
}

model CookingSessionItem {
  id         String         @id @default(uuid())
  sessionId  String
  session    CookingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  ingredient String
  price      Float?
  checked    Boolean        @default(false)
  checkedAt  DateTime?

  @@map("cooking_session_items")
}

model CookingSessionStep {
  id              String         @id @default(uuid())
  sessionId       String
  session         CookingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recipeId        String
  stepIndex       Int
  content         String
  durationSeconds Int?
  checked         Boolean        @default(false)
  checkedBy       String?
  checkedAt       DateTime?

  @@map("cooking_session_steps")
}

model CookingSessionPhoto {
  id         String         @id @default(uuid())
  sessionId  String
  session    CookingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  filename   String
  url        String
  createdAt  DateTime       @default(now())

  @@map("cooking_session_photos")
}

model RecipePhoto {
  id        String   @id @default(uuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  filename  String
  url       String
  createdAt DateTime @default(now())

  @@map("recipe_photos")
}

model FoodSpotPhoto {
  id         String   @id @default(uuid())
  foodSpotId String
  filename   String
  url        String
  createdAt  DateTime @default(now())
  foodSpot   FoodSpot @relation(fields: [foodSpotId], references: [id], onDelete: Cascade)

  @@map("food_spot_photos")
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum GoalStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}

model Sprint {
  id          String       @id @default(uuid())
  coupleId    String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      SprintStatus @default(PLANNING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  couple      Couple      @relation(fields: [coupleId], references: [id])
  goals       Goal[]

  @@index([coupleId])
  @@map("sprints")
}

model Tag {
  id       String @id @default(uuid())
  coupleId String
  name     String
  icon     String @default("🏷️")
  color    String?
  couple   Couple @relation(fields: [coupleId], references: [id])

  @@unique([name, coupleId])
  @@index([coupleId])
  @@map("tags")
}

model Achievement {
  id         String   @id @default(uuid())
  coupleId   String
  key        String
  unlockedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  couple     Couple   @relation(fields: [coupleId], references: [id])

  @@unique([key, coupleId])
  @@index([coupleId])
  @@map("achievements")
}

model AppSetting {
  id        String   @id @default(uuid())
  coupleId  String
  key       String
  value     String
  updatedAt DateTime @updatedAt
  couple    Couple  @relation(fields: [coupleId], references: [id])

  @@unique([key, coupleId])
  @@index([coupleId])
  @@map("app_settings")
}

model CustomAchievement {
  id          String    @id @default(uuid())
  coupleId    String
  title       String
  description String?
  icon        String    @default("🏅")
  unlocked    Boolean   @default(false)
  unlockedAt  DateTime?
  createdAt   DateTime  @default(now())
  couple      Couple   @relation(fields: [coupleId], references: [id])

  @@index([coupleId])
  @@map("custom_achievements")
}

model DateWish {
  id               String    @id @default(uuid())
  coupleId         String
  title            String
  description      String?
  category         String
  address          String?
  latitude         Float?
  longitude        Float?
  url              String?
  tags             String[]  @default([])
  done             Boolean   @default(false)
  doneAt           DateTime?
  linkedMomentId   String?
  linkedFoodSpotId String?
  createdBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  couple           Couple   @relation(fields: [coupleId], references: [id])

  @@index([coupleId])
  @@map("date_wishes")
}

model DatePlan {
  id        String         @id @default(uuid())
  coupleId  String
  title     String
  date      DateTime
  notes     String?
  status    String         @default("planned")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  couple    Couple        @relation(fields: [coupleId], references: [id])
  stops     DatePlanStop[]

  @@index([coupleId])
  @@map("date_plans")
}

model DatePlanStop {
  id          String         @id @default(uuid())
  planId      String
  plan        DatePlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  time        String
  title       String
  description String?
  address     String?
  latitude    Float?
  longitude   Float?
  url         String?
  tags        String[]       @default([])
  category    String?
  notes       String?
  order       Int
  done        Boolean        @default(false)
  doneAt      DateTime?
  wishId          String?
  linkedMomentId  String?
  linkedFoodSpotId String?
  cost        Float?
  createdAt   DateTime       @default(now())
  spots       DatePlanSpot[]

  @@map("date_plan_stops")
}

model DatePlanSpot {
  id        String      @id @default(uuid())
  stopId    String
  stop      DatePlanStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  title     String
  address   String?
  latitude  Float?
  longitude Float?
  url       String?
  notes     String?
  order     Int
  createdAt DateTime    @default(now())

  @@map("date_plan_spots")
}

model Expense {
  id          String   @id @default(uuid())
  coupleId    String
  amount      Float
  description String
  category    String
  date        DateTime
  note        String?
  receiptUrl  String?
  foodSpotId  String?
  datePlanId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  couple      Couple  @relation(fields: [coupleId], references: [id])

  @@index([coupleId])
  @@map("expenses")
}

model Goal {
  id          String       @id @default(uuid())
  coupleId    String
  title       String
  description String?
  status      GoalStatus   @default(TODO)
  priority    GoalPriority @default(MEDIUM)
  assignee    String?
  dueDate     DateTime?
  order       Int          @default(0)
  sprintId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  couple      Couple      @relation(fields: [coupleId], references: [id])
  sprint      Sprint?      @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@index([coupleId])
  @@map("goals")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ShareLink {
  id        String    @id @default(uuid())
  token     String    @unique
  type      String
  targetId  String
  coupleId  String
  expiresAt DateTime?
  viewCount Int       @default(0)
  createdAt DateTime  @default(now())
  couple    Couple    @relation(fields: [coupleId], references: [id])

  @@index([coupleId])
  @@map("share_links")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Moment {
  id          String        @id @default(uuid())
  title       String
  caption     String?
  date        DateTime
  latitude    Float?
  longitude   Float?
  location    String?
  tags        String[]
  spotifyUrl  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  photos      MomentPhoto[]
  audios      MomentAudio[]

  @@map("moments")
}

model MomentPhoto {
  id        String   @id @default(uuid())
  momentId  String
  filename  String
  url       String
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id], onDelete: Cascade)

  @@map("moment_photos")
}

model MomentAudio {
  id        String   @id @default(uuid())
  momentId  String
  filename  String
  url       String
  duration  Float?
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id], onDelete: Cascade)

  @@map("moment_audios")
}

model FoodSpot {
  id          String          @id @default(uuid())
  name        String
  description String?
  rating      Float           @default(0)
  latitude    Float?
  longitude   Float?
  location    String?
  tags        String[]
  priceRange  Int             @default(2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  photos      FoodSpotPhoto[]
  recipes     Recipe[]

  @@map("food_spots")
}

model Recipe {
  id          String        @id @default(uuid())
  title       String
  description String?
  ingredients String[]
  steps       String[]
  tags        String[]
  notes       String?
  foodSpotId  String?
  foodSpot    FoodSpot?     @relation(fields: [foodSpotId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  photos      RecipePhoto[]

  @@map("recipes")
}

model RecipePhoto {
  id        String   @id @default(uuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  filename  String
  url       String
  createdAt DateTime @default(now())

  @@map("recipe_photos")
}

model FoodSpotPhoto {
  id         String   @id @default(uuid())
  foodSpotId String
  filename   String
  url        String
  createdAt  DateTime @default(now())
  foodSpot   FoodSpot @relation(fields: [foodSpotId], references: [id], onDelete: Cascade)

  @@map("food_spot_photos")
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum GoalStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}

model Sprint {
  id          String       @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      SprintStatus @default(PLANNING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  goals       Goal[]

  @@map("sprints")
}

model Tag {
  id    String  @id @default(uuid())
  name  String  @unique
  icon  String  @default("🏷️")
  color String?

  @@map("tags")
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model Goal {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      GoalStatus   @default(TODO)
  priority    GoalPriority @default(MEDIUM)
  assignee    String?
  dueDate     DateTime?
  order       Int          @default(0)
  sprintId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  sprint      Sprint?      @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@map("goals")
}

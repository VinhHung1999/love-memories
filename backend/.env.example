# Database
DATABASE_URL="postgresql://user@localhost:5432/love_scrum"
PORT=5005

# File uploads
UPLOAD_DIR=./uploads
CDN_BASE_URL=https://your-cdn.example.com
CDN_API_KEY=your_cdn_api_key
CDN_PROJECT=love-scrum

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Google OAuth
# GOOGLE_CLIENT_IDS — comma-separated list of allowed client IDs (web, iOS, Android)
# Used as audience array in verifyIdToken — token aud differs per platform:
#   iOS native: aud = GOOGLE_IOS_CLIENT_ID
#   Android: aud = GOOGLE_ANDROID_CLIENT_ID (webClientId in RN app)
#   Web browser: aud = first client ID
GOOGLE_CLIENT_IDS=web_client_id.apps.googleusercontent.com,android_client_id.apps.googleusercontent.com,ios_client_id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=ios_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=android_client_id.apps.googleusercontent.com

# Web Push (VAPID)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@example.com

# Mapbox
MAPBOX_TOKEN=pk.your_mapbox_token

# CORS
ALLOWED_ORIGINS=http://localhost:3337,http://localhost:3338

# App URL (for share links, email verification)
APP_URL=https://your-app.example.com

# Apple Sign-In
# APPLE_CLIENT_IDS — comma-separated bundle IDs accepted as audience in Apple identity token verification.
# iOS token aud = iOS bundle ID. Support both prod + dev in one env var.
APPLE_CLIENT_IDS=com.yourcompany.yourapp,com.yourcompany.yourapp.dev

# AI
XAI_API_KEY=your_xai_api_key

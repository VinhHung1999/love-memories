# Copy to .env (dev) and .env.production.
# EXPO_PUBLIC_* are exposed at runtime via process.env.EXPO_PUBLIC_*.
# Non-public values live in app.config.ts extra and are read via expo-constants.

EXPO_PUBLIC_API_URL=https://dev-love-scrum-api.hungphu.work
EXPO_PUBLIC_APP_BASE_URL=https://dev.memoura.app

# Variant: "development" | "production" — read by app.config.ts to switch bundle IDs
APP_VARIANT=development

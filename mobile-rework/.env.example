# Copy to .env. EXPO_PUBLIC_* are exposed at runtime via process.env.EXPO_PUBLIC_*.
# Non-public values live in app.config.ts extra and are read via expo-constants.
# Dev vs prod is detected at build time via __DEV__ — no APP_VARIANT switch.

EXPO_PUBLIC_API_URL=https://dev-api.memoura.app
EXPO_PUBLIC_APP_BASE_URL=https://dev.memoura.app
# For prod TestFlight/App Store builds, use https://api.memoura.app + https://memoura.app

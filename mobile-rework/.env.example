# Copy to .env. EXPO_PUBLIC_* are inlined at runtime via process.env.EXPO_PUBLIC_*.
# Non-public values live in app.config.ts → extra and are read via expo-constants.
#
# Sprint 67 T448 — `app.config.ts` now owns the prod/dev API URL via the
# APP_VARIANT env var (or NODE_ENV during `expo start`). The default for any
# release build is PROD = api.memoura.app. The default for `expo start` is
# DEV = dev-api.memoura.app (NODE_ENV !== 'production').
#
# Use this file ONLY to point Metro at a non-default backend (e.g. a LAN dev
# server while debugging on a physical device). Leaving the values blank
# keeps the variant-driven default in app.config.ts intact.
#
# EXPO_PUBLIC_API_URL=http://192.168.1.5:5006
# EXPO_PUBLIC_APP_BASE_URL=http://192.168.1.5:3338
